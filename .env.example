# URL del cotizador (solo desarrollo local)
VITE_COTIZADOR_BASE_URL=http://localhost:3001

# Routing del iframe: premium (/cotizador?agent=) o legacy (/{slug})
# data-routing="premium" en el contenedor del widget
# VITE_COTIZADOR_ROUTING=premium

# URL pública del script del widget (referencia para integradores)
# VITE_WIDGET_SCRIPT_URL=https://widget.cotizaloantes.cl/cotizador-widget.js
